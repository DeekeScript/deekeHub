<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="theme-color" content="#1890ff" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="keywords" content="智能营销机器人，捧场式营销开创者与领导者, 短视频引流获客, 精准获客, 设备人获客, 设备人拓客, 设备人引流, 短视频引流" />
  <meta name="description" content="致力于打造短视频智能AI引流获客系统，帮助中小微商企拓客引流，解决客户成本居高不下的问题" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
  <title>DeekeHub - 智能多设备自动化管理平台</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <link rel="icon" href="<%= context.config.publicPath +'favicon.ico'%>" type="image/x-icon" />
  <link rel="preload" href="/logo.png" as="image" />
  <script src="/monaco-editor/config.js"></script>
</head>

<body>
  <div id="root">
    <style>
      html,body,#root{height:100%;margin:0;padding:0;background:#fff}
      #root{background-repeat:no-repeat;background-size:100% auto}
      .load-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;min-height:100vh;background:linear-gradient(180deg,#fff 0%,#f8faff 100%);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
      .load-logo{width:64px;height:64px;margin-bottom:24px;animation:loadPulse 2s ease-in-out infinite}
      .load-logo img{width:100%;height:100%;display:block}
      .load-dots{display:flex;gap:8px;margin-bottom:16px}
      .load-dot{width:8px;height:8px;border-radius:50%;background:#3B82F6;animation:loadBounce 1.4s ease-in-out infinite}
      .load-dot:nth-child(2){animation-delay:.15s}
      .load-dot:nth-child(3){animation-delay:.3s}
      .load-text{font-size:14px;color:#94A3B8;letter-spacing:.02em}
      @keyframes loadPulse{0%,100%{opacity:.8;transform:scale(1)}50%{opacity:1;transform:scale(1.05)}}
      @keyframes loadBounce{0%,80%,100%{transform:translateY(0);opacity:.4}40%{transform:translateY(-10px);opacity:1}}
      @keyframes loadFadeOut{to{opacity:0;visibility:hidden}}
    </style>
    <div class="load-wrap" id="load-screen">
      <div class="load-logo"><img src="/logo.png" alt="" /></div>
      <div class="load-dots"><span class="load-dot"></span><span class="load-dot"></span><span class="load-dot"></span></div>
      <div class="load-text">DeekeHub</div>
    </div>
    <script>
      // Hide loading screen once React mounts (umi injects scripts after root)
      var observer = new MutationObserver(function() {
        var screen = document.getElementById('load-screen');
        if (screen && document.getElementById('root').children.length > 1) {
          screen.style.animation = 'loadFadeOut .25s ease forwards';
          setTimeout(function() { screen && screen.remove(); }, 300);
          observer.disconnect();
        }
      });
      observer.observe(document.getElementById('root'), { childList: true });
    </script>
  </div>
</body>

</html>