APP_NAME="DKE"
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# Database Configuration
# ==========================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=deeke
DB_USERNAME=root
DB_PASSWORD=deeke-hub-2016
DB_PREFIX=dke_
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ==========================================
# Redis Configuration
# ==========================================
REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SELECT=15

# ==========================================
# Session Configuration
# ==========================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ==========================================
# Cache Configuration
# ==========================================
CACHE_DRIVER=redis
CACHE_PREFIX=deeke

# ==========================================
# Mail Configuration (if needed)
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# Broadcasting & Queue (if needed)
# ==========================================
BROADCAST_DRIVER=log
QUEUE_CONNECTION=redis

# ==========================================
# Filesystem Configuration
# ==========================================
FILESYSTEM_DISK=local
# ==========================================
