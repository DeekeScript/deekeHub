APP_NAME="DKE"
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# Database Configuration
# ==========================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=deeke
DB_USERNAME=root
DB_PASSWORD=123456-deeke-2026
DB_PREFIX=dke_
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ==========================================
# Redis Configuration
# ==========================================
REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SELECT=15

# ==========================================
# Session Configuration
# ==========================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ==========================================
# Cache Configuration
# ==========================================
CACHE_DRIVER=redis
CACHE_PREFIX=deeke

# ==========================================
# Mail Configuration (if needed)
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# Broadcasting & Queue (if needed)
# ==========================================
BROADCAST_DRIVER=log
QUEUE_CONNECTION=redis

# ==========================================
# Filesystem Configuration
# ==========================================
FILESYSTEM_DISK=local
# ==========================================
# Group Control Configuration
# ==========================================
# 是否启用群控功能（true/false）  私有化客户的可能，一般无需开启
ENABLE_GROUP_CONTROL=false

# DeekeScript：是否在管理员后台展示「DeekeScript」菜单并开放对应 API 权限（true/false）
DEEKESCRIPT_ADMIN_ENABLED=false
# DeekeScript：商户订单号前缀（默认 dk，须以 dk 开头）
DEEKESCRIPT_ORDER_NO_PREFIX=dk
# DeekeScript：验证码邮件主题中的名称（默认 DeekeScript，不用 APP_NAME）
DEEKESCRIPT_MAIL_BRAND=DeekeScript

# ==========================================
# Platform Feature Flags
# ==========================================
# 通过开关控制每个平台是否启用（true/false）
PLATFORM_DOUYIN_ENABLED=true
PLATFORM_WECHAT_ENABLED=true
PLATFORM_WECHAT_CHANNELS_ENABLED=true
PLATFORM_XIAOHONGSHU_ENABLED=true
PLATFORM_SYSTEM_ENABLED=true

# ==========================================
# Feature Flags
# ==========================================
# 是否启用语音服务（true/false）— 管理员后台「语音服务」菜单开关
ENABLE_VOICE_SERVICE=false
# 是否启用扣子智能体设置（true/false）— 管理员后台「系统管理 > 扣子智能体设置」菜单开关
ENABLE_KOUZI_SETTING=false
